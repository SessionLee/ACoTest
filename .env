# ACo 框架环境变量模板
# 复制此文件为 .env 并填入实际值

# ===========================================
# AI API 配置（必填）
# ===========================================

# AI API 基础 URL
# OpenRouter: https://openrouter.ai/api/v1
# Anthropic: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# AI API Key
# OpenRouter: sk-or-xxx
# Anthropic: sk-ant-xxx
ANTHROPIC_AUTH_TOKEN=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
ANTHROPIC_MODEL_NAME=minimax/minimax-m2.5
ANTHROPIC_API_KEY=""
# ===========================================
# GitHub 配置（必填）
# ===========================================

# GitHub 认证：使用 SSH 公钥（请参考 ACo Skill 文档配置）
# 无需在此处配置 Token

# ===========================================
# 通知配置（必填）
# ===========================================

# Bark 通知 URL
# 格式: https://api.day.app/your-device-key/标题/内容
BARK_URL=https://api.day.app/rSrprVQqJXAM4qQ7agcHY9

# ===========================================
# 测试配置（可选）
# ===========================================

# TestSprite API Key（用于自动化测试）
# 如不需要自动化测试，可以不填
# TESTSPRITE_API_KEY=

# ===========================================
# Claude Code 配置（可选）
# ===========================================

# 项目名称（用于通知显示）
PROJECT_NAME=ACoTest